{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "baseUrl": "../..",
    "paths": {
      "@guru-pintar/types": ["packages/types/src"],
      "@guru-pintar/types/*": ["packages/types/src/*"],
      "@guru-pintar/ai": ["packages/ai/src"],
      "@guru-pintar/ai/*": ["packages/ai/src/*"],
      "@guru-pintar/utils": ["packages/utils/src"],
      "@guru-pintar/utils/*": ["packages/utils/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../packages/**/*.ts"],
  "exclude": ["node_modules"]
}